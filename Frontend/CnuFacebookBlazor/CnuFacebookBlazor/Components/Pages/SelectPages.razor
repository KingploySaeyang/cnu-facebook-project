    // "เลือกทั้งหมด" ครั้งเดียว แทนที่จะต้องติ๊กทีละข้อ
    private void ToggleAll(ChangeEventArgs e)
    {
        bool val = (bool)(e.Value ?? false);// รับค่าจาก checkbox ว่า "เลือกทั้งหมด" ถูกติ๊กหรือไม่
        foreach (var p in pages) p.IsSelected = val;// ถ้า "เลือกทั้งหมด" ถูกติ๊ก ก็ให้ทุกเพจถูกติ๊กด้วย ถ้าไม่ถูกติ๊ก ก็ให้ทุกเพจไม่ถูกติ๊ก
    }

    private async Task SavePages()
    {
        // ตรวจสอบว่ามีการเลือกเพจที่ติ้ก
        var selected = pages.Where(p => p.IsSelected).ToList();
        if (selected.Count == 0) return;

        isSaving = true;
        saveError = "";
        StateHasChanged();

        try
        {
            var http = HttpFactory.CreateClient("CnuConnectAPI");

            var payload = selected.Select(page => new
            {
                AccessToken     = page.PageAccessToken,
                LongLivedToken  = longLivedToken,
                PageId          = page.PageId,
                PageName        = page.PageName,
                CreateUserID    = "3"
            }).ToList();

            var json    = System.Text.Json.JsonSerializer.Serialize(payload);
            var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");
            var res = await http.PostAsync("api/ApiFacebookCnu/OnInsertFacebookToken", content);

            if (res.IsSuccessStatusCode)
            {
                Nav.NavigateTo($"/dashboard?fbUserId={Uri.UnescapeDataString(fbUserId)}");
                return;
            }

            var errBody = await res.Content.ReadAsStringAsync();
            string errText = "";
            try { errText = System.Text.Json.JsonSerializer.Deserialize<string>(errBody) ?? errBody; }
            catch { errText = errBody; }

            if (errText.Contains("มีข้อมูลอยู่แล้ว") || errText.Contains("PageID"))
            {
                Nav.NavigateTo($"/dashboard?fbUserId={Uri.UnescapeDataString(fbUserId)}");
                return;
            }

            saveError = $"บันทึกไม่สำเร็จ: {errText}";
        }
        catch
        {
            saveError = "ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้ กรุณาลองใหม่";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void TestPages()
{
        Nav.NavigateTo($"/dashboard?fbUserId={Uri.EscapeDataString(fbUserId)}");
}

    // คลาสช่วยเก็บข้อมูลเพจที่ดึงมาจาก API
    private class PageItem
    {
        public string PageId { get; set; } = "";
        public string PageName { get; set; } = "";
        public string PictureUrl { get; set; } = "";
        public string PageAccessToken { get; set; } = "";
        public bool IsSelected { get; set; }
    }
}
